# Copy this file to .env and fill in your credentials.
# docker-compose reads .env automatically.
# Never commit .env to git.

# ── MLS credentials ───────────────────────────────────────────────────────────
MLS_USERNAME=your_mls_username_here
MLS_PASSWORD=your_mls_password_here

# ── MongoDB ───────────────────────────────────────────────────────────────────
# Used when running scripts directly on Mac (not via docker compose).
MONGO_URI=mongodb://mlsuser:mlspassword@localhost:27017/mls?authSource=admin
MONGO_DB=mls

# ── Browser (Mac local runs only) ─────────────────────────────────────────────
# Leave blank to auto-detect, or set explicitly:
#
#   CHROME_BIN=/Applications/Google Chrome.app/Contents/MacOS/Google Chrome
#   CHROMEDRIVER_BIN=   # leave empty → webdriver-manager downloads one automatically
#
# In Docker these are set in Dockerfile.app and point to /usr/bin/chromium.
CHROME_BIN=
CHROMEDRIVER_BIN=

# ── Misc ──────────────────────────────────────────────────────────────────────
# Set to "false" to watch the browser window (Mac only — headless must be true in Docker).
HEADLESS=false
